@page "/"

<PageTitle>DndCompanion</PageTitle>

<div class="row justify-content-center">
    <div class="col-12 col-lg-9">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h1 class="mb-2">DndCompanion</h1>
                        <p class="text-muted mb-0">Create or join a session.</p>
                    </div>
                </div>

                <div class="d-grid gap-2 d-md-flex">
                    <a class="btn btn-primary btn-lg flex-fill" href="/sessions/create">Create session</a>
                    <a class="btn btn-outline-primary btn-lg flex-fill" href="/sessions/join">Join session</a>
                </div>
            </div>
        </div>
    </div>
</div>
