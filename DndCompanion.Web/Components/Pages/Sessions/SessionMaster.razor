@page "/sessions/{SessionId:guid}/master"
@using DndCompanion.Application.Abstractions.Persistence
@using Domain.Entities
@using Domain.Enums
@using Web.Components.Shared

@inject IServiceScopeFactory ScopeFactory

@inject SessionNotificationService SessionNotificationService
@implements IDisposable

<h3>SessionMaster - WIP</h3>

@if (_session is null)
{
    <p>Loading...</p>
}
else
{
    <div class="container py-3">
        <div class="d-flex align-items-center mb-3">
            <h2 class="mb-0">Master Panel</h2>
        </div>
        
        <h5 class="text-muted mb-2">Characters</h5>
        <div class="row g-2">
            @foreach (var participant in _session.Participants.Where(p => p.Role == SessionRole.Player && p.Character is not null))
            {
                var hp = participant.Character!.Resources.FirstOrDefault(r => r.Type == ResourceType.HitPoints);
                <div class="col-6">
                    <div class="card p-3">
                        <div class="fw-semibold">@participant.Character!.Name</div>
                        <div class="small text-muted">@participant.DisplayName</div>
                        @if (hp is not null)
                        {
                            <div class="mt-2">
                                <span class="small text-muted">HP </span>
                                <span class="fw-semibold @(hp.CurrentValue == 0 ? "text-danger" : "")">
                                    @hp.CurrentValue/@hp.MaxValue
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }
            @if (!_session.Participants.Any(p => p.Role == SessionRole.Player && p.Character is not null))
            {
                <div class="col-12">    
                    <p class="text-muted">No players with characters yet.</p>
                </div>
            }
        </div>
    </div>
}

<SessionNavBar SessionId="@SessionId" ParticipantId="@ParticipantId" Role="@SessionRole.Master"/>

@code {
    [Parameter] public Guid SessionId { get; set; }
    [SupplyParameterFromQuery(Name = "participantId")] public Guid ParticipantId { get; set; }

    private Domain.Entities.Session? _session;

    protected override async Task OnInitializedAsync()
    {
        await LoadSessionAsync();
        SessionNotificationService.Subscribe(SessionId, OnSessionUpdated);
    }

    private async Task LoadSessionAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var repo = scope.ServiceProvider.GetRequiredService<ISessionRepository>();
        _session = await repo.FindByIdWithParticipantsAndCharactersAsync(SessionId);
    }

    private async Task OnSessionUpdated()
    {
        await LoadSessionAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SessionNotificationService.Unsubscribe(SessionId, OnSessionUpdated);
    }
}