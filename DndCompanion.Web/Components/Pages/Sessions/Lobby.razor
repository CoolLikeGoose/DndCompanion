@page "/sessions/{SessionId:guid}/lobby"
@using System.Security.Claims
@using DndCompanion.Application.Abstractions.Persistence
@using DndCompanion.Application.Features.Characters.CreateCharacter
@using DndCompanion.Application.Features.Characters.SelectCharacter
@using Domain.Entities
@inject CreateCharacterService CreateCharacterService
@inject SelectCharacterService SelectCharacterService
@inject ICharacterRepository CharacterRepository
@inject ISessionRepository SessionRepository
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Nav

<PageTitle>Choose character</PageTitle>

<div class="row justify-content-center">
    <div class="col-12 col-lg-9">
        <h1 class="mb-1">Choose your character</h1>
        <p class="text-muted mb-4">Session: @SessionId</p>
        
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger" role="alert">@_error</div>
        }
        
        @* exitsting characters *@
        @if (_userCharacters.Count > 0)
        {
            <h5 class="mb-3">Your characters</h5>
            <div class="row g-3 mb-4">
                @foreach (var character in _userCharacters)
                {
                    <div class="col-12 col-sm-6 col-lg-4">
                        <div class="card h-100">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@character.Name</h5>
                                <div class="mt-auto">
                                    <button class="btn btn-primary w-100"
                                            @onclick="() => SelectCharacter(character.Id)"
                                            disabled="@_isLoading">
                                        Play
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        
        @* create new character *@
        <h5 class="mb-3">New character</h5>
        <div class="row g-3">
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column gap-2">
                        <h5 class="card-title">Create new character</h5>
                        <input class="form-control" placeholder="Character name" @bind="_newCharacterName" disabled="@_isLoading"/>
                        <button class="btn btn-primary mt-auto" @onclick="CreateCharacter" disabled="@_isLoading">
                            @(_isLoading ? "Creating..." : "Create")
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">Import character</h5>
                        <p class="card-text text-muted small">TODO</p>
                        <button class="btn btn-outline-secondary mt-auto" disabled>Import</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private const string ParticipantQueryKey = "participantId";

    [Parameter] public Guid SessionId { get; set; }
    [SupplyParameterFromQuery(Name = ParticipantQueryKey)] public Guid ParticipantId { get; set; }

    private List<Character> _userCharacters = new();
    private string _newCharacterName = "";
    private string? _error;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        var participant = await SessionRepository.FindParticipantByIdAsync(ParticipantId);
        if (participant is null || participant.SessionId != SessionId)
        {
            _error = "Invalid session participant link";
            return;
        }

        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = state.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var raw = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(raw, out var id))
                _userCharacters = await CharacterRepository.GetByUserIdAsync(id);
        }
    }

    private async Task CreateCharacter()
    {
        if (string.IsNullOrWhiteSpace(_newCharacterName))
        {
            _error = "Character name is required";
            return;
        }
        
        _isLoading = true;
        _error = null;

        var result = await CreateCharacterService.ExecuteAsync(
            new CreateCharacterCommand(_newCharacterName, SessionId, ParticipantId));
        
        _isLoading = false;

        if (!result.IsSuccess)
        {
            _error = result.ErrorMessage;
            return;
        }
        
        Nav.NavigateTo($"sessions/{SessionId}?{ParticipantQueryKey}={ParticipantId}");
    }

    private async Task SelectCharacter(Guid characterId)
    {
        _isLoading = true;
        _error = null;

        var result = await SelectCharacterService.ExecuteAsync(
            new SelectCharacterCommand(characterId, SessionId, ParticipantId));
        
        _isLoading = false;

        if (!result.IsSuccess)
        {
            _error = result.ErrorMessage;
            return;
        }
        
        Nav.NavigateTo($"sessions/{SessionId}?{ParticipantQueryKey}={ParticipantId}");
    }
}